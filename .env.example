# Safe local-only defaults. Do not reuse these values outside local development.
GNXTHIRE_ENV=local
GNXTHIRE_APP_NAME=gNxtHire
GNXTHIRE_SERVICE_NAME=api-gateway
GNXTHIRE_VERSION=0.0.0-phase1
GNXTHIRE_DEBUG=false
GNXTHIRE_LOGGING_LEVEL=INFO
GNXTHIRE_REQUEST_ID_HEADER=x-request-id
GNXTHIRE_CORRELATION_ID_HEADER=x-correlation-id
GNXTHIRE_ENFORCE_RLS_CONTEXT=true
GNXTHIRE_RUN_MIGRATIONS_ON_STARTUP=false
GNXTHIRE_RUN_DATABASE_VALIDATION_ON_STARTUP=false
APP_ENV=local
APP_BASE_URL=http://localhost:8000
TENANT_APP_BASE_URL=http://localhost:5173
PLATFORM_ADMIN_APP_BASE_URL=http://localhost:5174

IDENTITY_ACCESS_TOKEN_SECRET=change-me-local-access-secret
IDENTITY_REFRESH_TOKEN_SECRET=change-me-local-refresh-secret
IDENTITY_MFA_CHALLENGE_SECRET=change-me-local-mfa-secret
IDENTITY_EMAIL_TOKEN_SECRET=change-me-local-email-token-secret
IDENTITY_PASSWORD_RESET_TOKEN_SECRET=change-me-local-reset-token-secret
IDENTITY_MFA_SECRET_ENCRYPTION_KEY=change-me-local-mfa-encryption-key
IDENTITY_TOKEN_ISSUER=gnxthire-identity
IDENTITY_TENANT_AUDIENCE=gnxthire-tenant-app
IDENTITY_PLATFORM_ADMIN_AUDIENCE=gnxthire-platform-admin
IDENTITY_ACCESS_TOKEN_EXPIRES_MINUTES=15
IDENTITY_REFRESH_TOKEN_EXPIRES_DAYS=30
IDENTITY_MFA_CHALLENGE_EXPIRES_MINUTES=5
IDENTITY_EMAIL_VERIFICATION_EXPIRES_HOURS=24
IDENTITY_PASSWORD_RESET_EXPIRES_MINUTES=30
IDENTITY_LOGIN_LOCKOUT_MAX_FAILED_ATTEMPTS=5
IDENTITY_LOGIN_LOCKOUT_WINDOW_MINUTES=15
IDENTITY_PLATFORM_ADMIN_LOGIN_LOCKOUT_MAX_FAILED_ATTEMPTS=5
IDENTITY_PLATFORM_ADMIN_LOGIN_LOCKOUT_WINDOW_MINUTES=15
PLATFORM_ADMIN_SEED_EMAIL=ankit@gnxtsystems.com
PLATFORM_ADMIN_SEED_PASSWORD=LocalTest@12345

PASSWORD_MIN_LENGTH=12
PASSWORD_MAX_LENGTH=128
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBER=true
PASSWORD_REQUIRE_SPECIAL=true
PASSWORD_PREVENT_EMAIL_SIMILARITY=true

MFA_TOTP_ISSUER=gNxtHire
MFA_TOTP_DIGITS=6
MFA_TOTP_INTERVAL_SECONDS=30
MFA_TOTP_VALID_WINDOW=1
MFA_RECOVERY_CODE_COUNT=10
MFA_RECOVERY_CODE_LENGTH=12

IDENTITY_EMAIL_DELIVERY_ENABLED=true
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false
SMTP_USE_SSL=false
SMTP_FROM_EMAIL=no-reply@local.gnxthire.com
SMTP_FROM_NAME=gNxtHire
IDENTITY_RATE_LIMIT_BACKEND=redis
FRONTEND_EMAIL_VERIFY_URL=http://localhost:5173/auth/verify-email
FRONTEND_PLATFORM_ADMIN_EMAIL_VERIFY_URL=http://localhost:5174/auth/verify-email?realm=platform
FRONTEND_PASSWORD_RESET_URL=http://localhost:5173/auth/reset-password
FRONTEND_PLATFORM_ADMIN_PASSWORD_RESET_URL=http://localhost:5174/auth/reset-password

POSTGRES_HOST=localhost
POSTGRES_PORT=45432
POSTGRES_DB=gnxthire_local
POSTGRES_USER=gnxthire
POSTGRES_PASSWORD=gnxthire_local_password
DATABASE_URL=postgresql+psycopg://gnxthire:gnxthire_local_password@localhost:45432/gnxthire_local
TEST_DATABASE_URL=postgresql+psycopg://gnxthire:gnxthire_local_password@localhost:45432/gnxthire_local_test

REDIS_URL=redis://localhost:6379/0
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
OPENSEARCH_URL=http://localhost:9200
MAILPIT_SMTP_HOST=localhost
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_URL=http://localhost:8025
